# TradeOS V2 — Environment Configuration
# Copy this to .env and fill in your API keys

# ── AI (Required for decision synthesis + sentiment)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Market Data (Optional — scraping works without these)
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VINTAGE_API_KEY=your_alpha_vantage_key_here
TWELVE_DATA_API_KEY=your_twelve_data_key_here
FINANCIAL_MODELING_PREP=your_fmp_key_here

# ── Security
SECRET_KEY=change-this-to-a-random-string-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_PER_MINUTE=30

# ── App
DEBUG=false
HOST=0.0.0.0
PORT=8080
